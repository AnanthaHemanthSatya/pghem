{
  "info": {
    "name": "PGXplore API",
    "description": "Complete API collection for PGXplore backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password@123\",\n  \"phone\": \"9876543210\",\n  \"role\": \"USER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.data) {",
                "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@pgxplore.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh-token"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ananya@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/forgot-password"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset-token-here\",\n  \"newPassword\": \"NewPassword@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/reset-password"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Get Favorites",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/me/favorites"
          }
        },
        {
          "name": "Add Favorite",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/me/favorites/1"
          }
        },
        {
          "name": "Remove Favorite",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/me/favorites/1"
          }
        }
      ]
    },
    {
      "name": "PG",
      "item": [
        {
          "name": "Create PG",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New PG Listing\",\n  \"description\": \"A great PG\",\n  \"address\": \"123 Main St\",\n  \"city\": \"Chennai\",\n  \"area\": \"Tambaram\",\n  \"rent\": 6000,\n  \"deposit\": 5000,\n  \"gender\": \"BOYS\",\n  \"amenities\": [\"WiFi\",\"AC\"],\n  \"availableBeds\": 3,\n  \"availableRooms\": 2,\n  \"foodAvailable\": true,\n  \"contactNumber\": \"9876543210\"\n}"
            },
            "url": "{{baseUrl}}/api/pg"
          }
        },
        {
          "name": "Get PG by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pg/1"
          }
        },
        {
          "name": "List All PGs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pg/all?page=0&size=10"
          }
        },
        {
          "name": "Search PGs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/pg/search?city=Chennai&maxRent=7000&wifi=true&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pg", "search"],
              "query": [
                { "key": "city", "value": "Chennai" },
                { "key": "maxRent", "value": "7000" },
                { "key": "wifi", "value": "true" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pgId\": 1,\n  \"rating\": 5,\n  \"reviewText\": \"Excellent PG with great amenities!\"\n}"
            },
            "url": "{{baseUrl}}/api/reviews"
          }
        },
        {
          "name": "Get Reviews by PG",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reviews/pg/1?page=0&size=10"
          }
        }
      ]
    },
    {
      "name": "Images",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "pgId", "value": "1", "type": "text" },
                { "key": "primary", "value": "true", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/api/images/upload"
          }
        }
      ]
    },
    {
      "name": "Inquiry",
      "item": [
        {
          "name": "Submit Inquiry",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pgId\": 1,\n  \"message\": \"Is a single room available?\",\n  \"contactNumber\": \"9876543210\"\n}"
            },
            "url": "{{baseUrl}}/api/inquiries"
          }
        }
      ]
    },
    {
      "name": "Recently Viewed",
      "item": [
        {
          "name": "Track View",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/recently-viewed/1"
          }
        },
        {
          "name": "List Recently Viewed",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/recently-viewed"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Verify Owner",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/admin/verify-owner/2"
          }
        }
      ]
    },
    {
      "name": "AI Search",
      "item": [
        {
          "name": "Natural Language Search",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Boys PG under 7000 in Chennai with WiFi\"\n}"
            },
            "url": "{{baseUrl}}/api/search/natural"
          }
        }
      ]
    }
  ]
}
